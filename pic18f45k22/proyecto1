#include <xc.h>
#include <stdio.h>
#include <string.h>

#define _XTAL_FREQ 16000000 // Oscilador configurado a 16 MHz

// --- DEFINICIÓN DE PINES PARA LA LCD ---
#define RS PORTEbits.RE1
#define E  PORTEbits.RE0
#define D4 PORTDbits.RD0
#define D5 PORTDbits.RD1
#define D6 PORTDbits.RD2
#define D7 PORTDbits.RD3

// --- DEFINICIÓN DE PINES PARA MOTORES ---
#define MOT_IZQ_A PORTBbits.RB0
#define MOT_IZQ_B PORTBbits.RB1
#define MOT_DER_A PORTBbits.RB2
#define MOT_DER_B PORTBbits.RB3

// --- DEFINICIÓN DEL SENSOR ---
#define SENSOR PORTEbits.RE2

// --- PROTOTIPOS DE FUNCIONES ---
void LCD_Cmd(unsigned char cmd);
void LCD_Char(char data);
void LCD_Init(void);
void LCD_String(char *str);
void LCD_Set_Cursor(char row, char col);
void UART_Init(void);
void UART_Write_Text(char *text);
void Motores_Control(char dir);

void main(void) {
    // Configuración de Pines Digitales y Analógicos
    ANSELD = 0x00; // Puerto D como digital (LCD)
    ANSELE = 0x00; // Puerto E como digital (LCD y Sensor)
    ANSELB = 0x00; // Puerto B como digital (Motores)
    ANSELC = 0x00; // Puerto C como digital (UART)
    
    // Configuración de Direcciones (TRIS)
    TRISD = 0xF0;  // RD0-RD3 como salidas para LCD
    TRISEbits.TRISE0 = 0; // RE0 como salida (E)
    TRISEbits.TRISE1 = 0; // RE1 como salida (RS)
    TRISEbits.TRISE2 = 1; // RE2 como ENTRADA para el Sensor IR
    TRISB = 0xF0;  // RB0-RB3 como salidas para Motores
    
    // Inicialización de periféricos
    LCD_Init();
    UART_Init();
    
    LCD_Set_Cursor(1, 1);
    LCD_String("Robot Inicializado");
    __delay_ms(1000);
    LCD_Cmd(0x01); // Limpiar pantalla
    
    char comando_wifi = 'S'; // Estado inicial: Detenido
    
    while(1) {
        // 1. Monitoreo prioritario del sensor infrarrojo (>10mm)
        if (SENSOR == 0) { 
            // Si el TCRT5000/FC-51 detecta obstáculo (da un 0 lógico)
            Motores_Control('S'); // Detener de inmediato por seguridad
            comando_wifi = 'S';   // Forzar estado detenido
            
            LCD_Set_Cursor(1, 1);
            LCD_String("Dir: DETENIDO   ");
            LCD_Set_Cursor(2, 1);
            LCD_String("OBSTACULO: SI   ");
            
            // Avisa a la página web mediante el ESP8266
            UART_Write_Text("ALERTA:OBSTACULO\r\n");
            __delay_ms(100); 
        } 
        else {
            // Si el camino está limpio, actualiza el estado en la LCD
            LCD_Set_Cursor(2, 1);
            LCD_String("OBSTACULO: NO   ");
        }
        
        // 2. Recepción de comandos desde la interfaz HTML (WiFi)
        if (PIR1bits.RCIF) { 
            char dato_recibido = RCREG1; 
            
            // Si hay un obstáculo enfrente, ignorar comando de ir hacia adelante
            if (SENSOR == 0 && dato_recibido == 'F') {
                Motores_Control('S');
            } else {
                comando_wifi = dato_recibido;
                Motores_Control(comando_wifi);
            }
        }
    }
}

// --- CONTROL DE DIRECCIÓN DE MOTORES ---
void Motores_Control(char dir) {
    switch(dir) {
        case 'F': // Adelante (Forward)
            MOT_IZQ_A = 1; MOT_IZQ_B = 0;
            MOT_DER_A = 1; MOT_DER_B = 0;
            LCD_Set_Cursor(1, 1); LCD_String("Dir: ADELANTE   ");
            break;
        case 'B': // Atrás (Backward)
            MOT_IZQ_A = 0; MOT_IZQ_B = 1;
            MOT_DER_A = 0; MOT_DER_B = 1;
            LCD_Set_Cursor(1, 1); LCD_String("Dir: ATRAS      ");
            break;
        case 'L': // Izquierda (Left)
            MOT_IZQ_A = 0; MOT_IZQ_B = 1;
            MOT_DER_A = 1; MOT_DER_B = 0;
            LCD_Set_Cursor(1, 1); LCD_String("Dir: IZQUIERDA  ");
            break;
        case 'R': // Derecha (Right)
            MOT_IZQ_A = 1; MOT_IZQ_B = 0;
            MOT_DER_A = 0; MOT_DER_B = 1;
            LCD_Set_Cursor(1, 1); LCD_String("Dir: DERECHA    ");
            break;
        case 'S': // Detenerse (Stop)
        default:
            MOT_IZQ_A = 0; MOT_IZQ_B = 0;
            MOT_DER_A = 0; MOT_DER_B = 0;
            LCD_Set_Cursor(1, 1); LCD_String("Dir: DETENIDO   ");
            break;
    }
}

// --- CONFIGURACIÓN SERIAL UART (9600 Baudios) ---
void UART_Init(void) {
    TRISCbits.TRISC6 = 1; 
    TRISCbits.TRISC7 = 1;
    SPBRG1 = 25; // 9600 baudios con Fosc = 16MHz
    TXSTA1bits.BRGH = 0;
    RCSTA1bits.SPEN = 1;
    RCSTA1bits.CREN = 1;
    TXSTA1bits.TXEN = 1;
}

void UART_Write_Text(char *text) {
    while(*text) {
        while(!TXSTA1bits.TRMT);
        TXREG1 = *text++;
    }
}

// --- LIBRERÍA LCD 4-BITS (ESTILO TALLERES) ---
void LCD_Pulse(void) {
    E = 1; __delay_us(5); E = 0; __delay_us(5);
}

void LCD_Out_4bit(unsigned char val) {
    D4 = (val >> 0) & 1;
    D5 = (val >> 1) & 1;
    D6 = (val >> 2) & 1;
    D7 = (val >> 3) & 1;
}

void LCD_Cmd(unsigned char cmd) {
    RS = 0;
    LCD_Out_4bit(cmd >> 4); LCD_Pulse(); // Bits altos
    LCD_Out_4bit(cmd);      LCD_Pulse(); // Bits bajos
    __delay_ms(2);
}

void LCD_Char(char data) {
    RS = 1;
    LCD_Out_4bit(data >> 4); LCD_Pulse();
    LCD_Out_4bit(data);      LCD_Pulse();
    __delay_us(50);
}

void LCD_Init(void) {
    __delay_ms(20);
    RS = 0; E = 0;
    LCD_Out_4bit(0x03); LCD_Pulse(); __delay_ms(5);
    LCD_Out_4bit(0x03); LCD_Pulse(); __delay_us(150);
    LCD_Out_4bit(0x03); LCD_Pulse();
    LCD_Out_4bit(0x02); LCD_Pulse(); // Modo 4 bits
    
    LCD_Cmd(0x28); // 4 bits, 2 líneas, 5x7 font
    LCD_Cmd(0x0C); // Display ON, Cursor OFF
    LCD_Cmd(0x06); // Incremento automático
    LCD_Cmd(0x01); // Limpiar pantalla
}

void LCD_String(char *str) {
    while(*str) LCD_Char(*str++);
}

void LCD_Set_Cursor(char row, char col) {
    char address = (row == 1) ? (0x80 + col - 1) : (0xC0 + col - 1);
    LCD_Cmd(address);
}
